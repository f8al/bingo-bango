# Copy to `.env` and fill in your Spotify app's client id.
# Under PKCE the client id is PUBLIC (not a secret) — safe to commit to a build.
#
# Create an app at https://developer.spotify.com/dashboard and add your redirect
# URI(s) there, exactly matching what the app uses:
#   - Local dev:   http://127.0.0.1:5173/callback
#   - GitHub Pages: https://<user>.github.io/bingo-bango/callback
#
# Leave unset to run the app in demo mode (built-in song pool, no login).

VITE_SPOTIFY_CLIENT_ID=

# Optional: override the redirect URI. Defaults to `<origin><base>callback`.
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
